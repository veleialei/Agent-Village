PORT=3000

# Supabase — project URL and keys from Settings → API in your Supabase dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# LLM provider API key — see backend/app/services/llm.py to swap providers
# Default implementation uses Google Gemini (free key at https://aistudio.google.com)
LLM_API_KEY=your-llm-api-key

# How often (seconds) the proactive worker checks all agents
SCHEDULER_INTERVAL=300
